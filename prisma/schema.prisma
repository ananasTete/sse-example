generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Chat {
  id              String    @id
  userId          String    @default("local-user")
  title           String?
  cursorMessageId String?
  settingsJson    Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  messages        Message[]
  runs            ChatRun[]

  @@index([userId, updatedAt])
}

model Message {
  id        String   @id
  chatId    String
  parentId  String?
  role      String
  partsJson Json
  model     String?
  status    String
  seq       Int
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, seq])
  @@index([chatId, parentId, createdAt])
  @@unique([chatId, seq])
}

model ChatRun {
  id                 String        @id
  chatId             String
  userId             String
  assistantMessageId String
  parentMessageId    String?
  resumeToken        String
  status             String
  lastEventSeq       Int           @default(0)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  finishedAt         DateTime?
  chat               Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  events             ChatRunEvent[]

  @@index([chatId, status, createdAt])
  @@index([userId, status, createdAt])
}

model ChatRunEvent {
  id          String   @id
  runId       String
  seq         Int
  event       String
  payloadJson Json
  createdAt   DateTime @default(now())
  run         ChatRun  @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt])
  @@unique([runId, seq])
}
